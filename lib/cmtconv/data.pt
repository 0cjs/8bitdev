from    cmtconv.data  import *
import  pytest

TESTBLOCK = bytes([
    0x02, 0x2A,             # magic number
    0x03, 0x04,             # block no., datalen
    0x78, 0x80,             # address (big-endian)
    0xAA, 0x55, 0xAA, 0x55, # data
    0x29                    # checksum
])

####################################################################
#   Creating blocks from values, as when writing them to tape

def test_make_block_without_checksum():
    data  = b'\xAA\x55\xAA\x55'
    block = Block.make(3, 0x7880, data)
    assert            False is block.is_tail()
    assert                3 == block.blockno
    assert           0x7880 == block.addr
    assert                4 == block.datalen
    assert             data == block.data
    assert             0x29 == block.checksum()
    assert        TESTBLOCK == block.to_bytes()

    assert 'cmtconv.data.Block(blockno=0x3, addr=0x7880, data={})' \
        .format(repr(data)) \
        == repr(block) == str(block)

def test_make_block_with_checksum():
    args = (3, 0x7880, b'\xAA\x55\xAA\x55')
    Block.make(*args, checksum=0x29)
    with pytest.raises(Block.ChecksumError) as ex:
        Block.make(*args, checksum=0xEE)
    assert ex.match('expected=EE actual=29')

def test_fullsize_block():
    block = Block(8, 0, bytes(0x100))
    assert            0x100 == block.datalen
    assert                0 == block.to_bytes()[3]

def test_setdata_regular():
    block = Block.make(3, 0x7880)

    with pytest.raises(AttributeError) as ex:
        block.data = b''
    assert ex.match("can't set attribute")

    block.setdata(b'\xAA\x55\xAA\x55'); assert 0x29 == block.checksum()
    block.setdata(b'\xAA\x55\xAA\x55', checksum=0x29)

    block.setdata(b'\xAA\x56\xAA\x57'); assert 0x2C == block.checksum()
    block.setdata(b'\xAA\x56\xAA\x57', checksum=0x2C)

    with pytest.raises(Block.ChecksumError) as ex:
        block.setdata(b'\xAA\x55\xAA\x55', checksum=0xEE)
    assert ex.match('expected=EE actual=29')

def test_make_tail():
    block = Block.make_tail(0x789A)
    assert             True is block.is_tail()
    assert              255 == block.blockno
    assert                0 == block.datalen
    assert           0x789A == block.addr
    assert              b'' == block.data
    assert                0 == block.checksum()

    bb = (  b'\x02\x2A'     # magic
            b'\xFF\xFF'     # blockno and datalen identify a tail block
            b'\x78\x9A'     # address
            b'\x00'         # checksum always 0 for tail block
    )
    assert              bb == block.to_bytes()

    assert 'cmtconv.data.TailBlock(addr=0x789a)' == repr(block) == str(block)

    with pytest.raises(AttributeError) as ex:
        block.data = b''
    assert ex.match("can't set attribute")

def test_setdata_tail():
    ' Setting data on the tail would be used to confirm the checksum. '
    block = Block.make_tail(0x0A0B)
    block.setdata(b'', 0)
    with pytest.raises(Block.ChecksumError): block.setdata(b'', 0x01)
    with pytest.raises(ValueError):          block.setdata(b' ')


####################################################################
#   Creating blocks from bytes, as when reading them from tape

def test_from_header_badlen():
    with pytest.raises(ValueError) as ex:
        Block.from_header(b'\x02\x2B 1234')
    assert ex.match('Bad length: expected=6 actual=7')

def test_from_header_badmagic():
    with pytest.raises(ValueError) as ex:
        Block.from_header(b'\x02\x2B 123')
    assert ex.match('Bad magic: expected=022A actual=022B')

def test_from_header_regular():
    (block, datalen) = Block.from_header(TESTBLOCK[0:6])
    assert                3 == block.blockno
    assert           0x7880 == block.addr
    assert           (4, 0) == (datalen, block.datalen)
    assert              b'' == block.data
    assert            False is block.is_tail()

def test_from_header_tail():
    header = bytes([ 0x02, 0x2A, 0xFF, 0xFF, 0x00, 0x09 ])
    (block, datalen) = Block.from_header(header)
    assert             0xFF == block.blockno
    assert           0x0009 == block.addr
    assert           (0, 0) == (datalen, block.datalen)
    assert              b'' == block.data
    assert             True is block.is_tail()
