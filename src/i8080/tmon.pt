from    testmc.i8080  import  Machine
import  pytest

test_rig = '''
            relaxed on
            cpu 8080
            z80syntax exclusive
            org $8000
            include testmc/i8080/tmc/biosdef.i80

tmon_ram    equ  $7000
tmon_rom    equ  $8000

            include src/i8080/tmon.i80

            ;   data for testing E command and similar
            org  $12AB
utest_data  db   $FF, $00, $12, $23, $34, $45, $56, $67
            db   $78, $89, $9A, $AB, $BC, $CD, $DE, $EF
'''

param = pytest.mark.parametrize

####################################################################
#   Support routines

@param('input, expected', [
    ('\n',    True), ('\r',    True),
    ('\x09', False), ('\x0B', False),
    ('\x0C', False), ('\x0E', False),
    ('\x8A', False),
])
def test_execchar(m, S, R, input, expected):
    m.call(S.execchar, R(a=ord(input), Z=not expected), trace=1)
    assert R(Z=expected) == m.regs

@param('input, expected', [
    ('\x15',  True), ('\x18',  True),
    ('\x14', False), ('\x16', False),
    ('\x17', False), ('\x19', False),
    ('\x85', False),
])
def test_cancelchar(m, S, R, input, expected):
    m.call(S.cancelchar, R(a=ord(input), Z=not expected), trace=1)
    assert R(Z=expected) == m.regs

####################################################################
#   Options and command parsing

@param('input, output, continued', [
    #   All non-printable characters are "bad command" when waiting for command.
    (b'\x00',   b'.\a\r',     True ),
    (b'\n',     b'.\a\r',     True ),
    (b'\r',     b'.\a\r',     True ),
    (b'\x1F',   b'.\a\r',     True ),
    (b'\x7F',   b'.\a\r',     True ),

    #   Printable invalid commands are echoed and backspaced over to
    #   leave the incorrect command visible.
    (b' ',      b'. \a\r',  True),
    (b'!',      b'.!\a\r',  True),
    (b'~',      b'.~\a\r',  True),

    #   Q command is the simplest to test
    (b'q\n',    b'.q\n',    False),     # lower case command
    (b'Q  \r',  b'.Q  \n',  False),     # upper case command, spaces ignored
    (b'q\x15',  b'.q\\\n',  True ),     # cancel with Ctrl-U
    (b'q\x18',  b'.q\\\n',  True ),     # cancel with Ctrl-X
])
def test_prompt(m, loadbios, S, R,  input, output, continued):
    pnext = S['prompt.next']
    istream, ostream = loadbios(input=input)
    m.call(S.prompt, stopat=[pnext])

    print(f'pnext=${pnext:04X}  {m.regs}')
    assert (           b'',             output,           continued) \
        == (istream.read(), ostream.getvalue(),  pnext == m.regs.pc)

def test_e_defaults(m, S, R, loadbios):
    _, ostream = loadbios(input=b'\n')
    m.call(S.init, stopat=[S['init.end']])           # testing default values
    m.call(S.cmd_E, stopat=[S['cmd_E.done']])
    s = ostream.getvalue()
    assert b'0000: 00' in s
    assert b'0018: 00' in s
    assert s.endswith(b'\n')

def test_e_settings(m, loadbios, S, R):
    _, ostream = loadbios(input=b'\n')
    #   2 lines of 5 bytes of known non-zero data.
    m.depword(S.optEs, S.utest_data)
    m.deposit(S.optEl, 2)
    m.deposit(S.optEw, 5)
    m.call(S.cmd_E, stopat=[S['cmd_E.done']])
    assert b'\n12AB: FF 00 12 23 34\n12B0: 45 56 67 78 89\n' \
        == ostream.getvalue()
