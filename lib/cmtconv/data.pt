from    cmtconv.data  import *
import  pytest

TESTBLOCK = bytes([
    0x02, 0x2A,             # magic number
    0x03, 0x04,             # block no., datalen
    0x78, 0x80,             # address (big-endian)
    0xAA, 0x55, 0xAA, 0x55, # data
    0x29                    # checksum
])

def test_badmagic():
    with pytest.raises(ValueError) as ex:
        BlockHeader.from_bytes(b'\x02\x2B')
    assert ex.match('Bad magic')

def test_makeblock():
    block = BlockHeader.make(3, 4, 0x7880)
    assert                3 == block.blockno
    assert                4 == block.datalen
    assert           0x7880 == block.addr
    assert            False is block.is_tail()
    assert   TESTBLOCK[0:6] == block.to_bytes()

def test_make_tail():
    block = Block.make_tail(0x789A)
    assert              255 == block.header.blockno

    #   XXX A tail block is identified by having 255 as length value, as well
    #   as block number, but should we be returning that or 0 in the API?
    assert              255 == block.header.datalen

    assert           0x789A == block.header.addr
    assert             True is block.header.is_tail()
    assert             None is block.data

def test_block_from_bytes():
    block = BlockHeader.from_bytes(TESTBLOCK)
    assert                3 == block.blockno
    assert                4 == block.datalen
    assert           0x7880 == block.addr
    assert            False is block.is_tail()

    s = 'cmtconv.data.BlockHeader(blockno=0x3, datalen=0x4, addr=0x7880)'
    assert                s == repr(block)
    assert                s == str(block)


def test_checksum():
    block = Block(
        BlockHeader.from_bytes(TESTBLOCK), TESTBLOCK[6:-1])
    assert TESTBLOCK[-1] == block.checksum()
    assert str(block)
